# ============================================================
# Sahel Job Offers API — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=*

# Database (PostgreSQL) - Use 'db:5432' for Docker, or '127.0.0.1:5433' for local dev with docker db
DATABASE_URL=postgres://sahel_user:sahel123@db:5432/sahel_db

# Redis - Use 'redis:6379' for Docker, or '127.0.0.1:6380' for local dev with docker redis
REDIS_URL=redis://redis:6379/1

# Orange SMS API (Burkina Faso)
ORANGE_CLIENT_ID=your_orange_client_id
ORANGE_CLIENT_SECRET=your_orange_client_secret
ORANGE_AUTH_HEADER=Basic your_base64_encoded_credentials
ORANGE_SENDER_ADDRESS=tel:+226XXXXXXXX
